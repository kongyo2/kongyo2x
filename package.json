{
  "name": "@kongyo2/kongyo2x",
  "version": "0.4.0",
  "description": "Image super-resolution in TypeScript with a Rust/WebAssembly compute core: MLPconv networks trained from scratch, with a pure-TypeScript fallback.",
  "type": "module",
  "license": "MIT",
  "author": "kongyo2",
  "homepage": "https://github.com/kongyo2/kongyo2x#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kongyo2/kongyo2x.git"
  },
  "bugs": {
    "url": "https://github.com/kongyo2/kongyo2x/issues"
  },
  "keywords": [
    "super-resolution",
    "upscale",
    "image",
    "waifu2x",
    "denoise",
    "brain.js",
    "mlpconv",
    "neural-network",
    "typescript",
    "webassembly",
    "wasm",
    "rust"
  ],
  "bin": {
    "kongyo2x": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "models",
    "wasm/kongyo2x.wasm",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "build:wasm": "bash scripts/build-wasm.sh",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint --format agent",
    "lint:fix": "oxlint --fix",
    "lint:strict": "oxlint --deny-warnings",
    "test": "vitest run",
    "cli": "tsx src/cli.ts",
    "train": "tsx scripts/train.ts"
  },
  "dependencies": {
    "jpeg-js": "0.4.4",
    "pngjs": "7.0.0"
  },
  "optionalDependencies": {
    "brain.js": "2.0.0-beta.24"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/pngjs": "6.0.5",
    "oxlint": "^1.72.0",
    "prettier": "3.4.2",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
